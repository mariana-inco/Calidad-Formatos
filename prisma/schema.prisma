generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String
  role      String
  position  String?
  process   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, company, role])
  @@index([company, role, active])
  @@map("users")
}

model AppCounter {
  key   String @id
  value Int    @default(0)

  @@map("app_counters")
}

model ChangeRequest {
  id                     String   @id @default(cuid())
  code                   String   @unique
  company                String
  process                String
  leaderUserId           String?
  leaderName             String
  creatorUserId          String
  creatorName            String
  currentState           String   @default("BORRADOR")
  currentResponsibleRole String
  currentResponsibleId   String?
  currentResponsibleName String?
  selectedApproverId     String?
  selectedApproverName   String?
  selectedApproverRole   String?
  changeTypes            String
  analysis               String
  implementationPlan     String
  qualityValidation      String?
  correctionNotes        String?
  approvedAt             DateTime?
  followupStartedAt      DateTime?
  closeDueAt             DateTime?
  closedAt               DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  approvals ChangeApproval[]
  followups ChangeFollowup[]
  history   ChangeHistory[]

  @@index([company])
  @@index([process])
  @@index([creatorUserId])
  @@index([leaderUserId])
  @@index([currentState])
  @@index([currentResponsibleRole, currentResponsibleId])
  @@map("change_requests")
}

model ChangeApproval {
  id              String   @id @default(cuid())
  changeRequestId String
  approverUserId  String?
  approverName    String
  approverRole    String
  approved        Boolean
  position        String?
  observations    String?
  signature       String?
  approvedAt      DateTime
  createdAt       DateTime @default(now())

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@index([approverUserId])
  @@map("change_approvals")
}

model ChangeFollowup {
  id                String   @id @default(cuid())
  changeRequestId   String
  responsibleUserId String?
  responsibleName   String
  effective         Boolean
  observations      String?
  actions           String?
  position          String?
  followupAt        DateTime
  closedAt          DateTime
  createdAt         DateTime @default(now())

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@index([responsibleUserId])
  @@map("change_followups")
}

model ChangeHistory {
  id                       String   @id @default(cuid())
  changeRequestId          String
  fromState                String?
  toState                  String
  action                   String
  userId                   String?
  userName                 String
  role                     String?
  position                 String?
  observation              String?
  selectedApproverId       String?
  selectedApproverName     String?
  createdAt                DateTime @default(now())

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)

  @@index([changeRequestId])
  @@index([createdAt])
  @@map("change_history")
}

model SolicitudCompra {
  id                   Int                    @id @default(autoincrement())
  numero_solicitud     String                 @unique
  id_usuario           String
  id_aprobador         String?
  centro_operacion     String
  tipo_documento       String?
  fecha_aprobacion     DateTime?
  referencia_documento String
  estado               EstadoSolicitudCompra @default(PENDIENTE)
  notas                String
  observacion          String?
  cotizacion_adjunto   Json?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  SolicitudCompraItem  SolicitudCompraItem[]

  @@index([estado])
  @@index([id_aprobador])
  @@index([id_usuario])
  @@index([numero_solicitud])
}

model SolicitudCompraItem {
  id                  Int             @id @default(autoincrement())
  solicitud_compra_id Int
  item                String
  centro_operacion    String?
  centro_costo        String
  bodega              String?
  motivo              String?
  unidad_negocio      String?
  descripcion_detalle String
  unidad              String
  es_servicio         Boolean         @default(false)
  notas               String?
  activo              Boolean         @default(true)
  created_at          DateTime        @default(now())
  updated_at          DateTime
  cantidad_solicitada Int             @default(1)
  precio_sugerido     String?
  SolicitudCompra     SolicitudCompra @relation(fields: [solicitud_compra_id], references: [id], onDelete: Cascade)

  @@index([activo])
  @@index([solicitud_compra_id])
}

enum EstadoSolicitudCompra {
  PENDIENTE
  EN_PROGRESO
  APROBADA
  RECHAZADA
  COMPLETADA
}
